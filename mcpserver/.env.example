# Network: "mainnet" or "testnet" (defaults to mainnet)
# Mainnet: Monad chain 143, rpc.monad.xyz
# Testnet: Monad chain 10143, testnet-rpc.monad.xyz
AMMPLIFY_NETWORK=mainnet

# Optional overrides (auto-set by network selection)
# AMMPLIFY_RPC_URL=https://rpc.monad.xyz
# AMMPLIFY_CHAIN_ID=143
# AMMPLIFY_ADDRESSES_FILE=./addresses/monad-mainnet.json

# Required for write operations (transaction signing)
AMMPLIFY_PRIVATE_KEY=0x...

# Optional
AMMPLIFY_MIDDLEWARE_URL=https://api.ammplify.xyz
PORT=3100
